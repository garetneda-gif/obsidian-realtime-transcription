{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "functions": {
    "api/asr-proxy.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/captcha/image",
      "destination": "/api/captcha"
    },
    {
      "source": "/api/auth/oauth/providers",
      "destination": "/api/oauth_providers"
    },
    {
      "source": "/api/auth/browser-login",
      "destination": "/api/browser_login"
    },
    {
      "source": "/api/asr/proxy",
      "destination": "/api/asr-proxy"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
